model Appointment {
  id                              String   @id @default(uuid()) @db.Uuid
  businessId                      String   @map("business_id") @db.Uuid
  customerId                      String   @map("customer_id") @db.Uuid
  vehicleId                       String   @map("vehicle_id") @db.Uuid
  zoneId                          String   @map("zone_id") @db.Uuid
  resourceId                      String   @map("resource_id") @db.Uuid
  startsAt                        DateTime @map("starts_at") @db.Timestamptz
  endsAt                          DateTime @map("ends_at") @db.Timestamptz
  durationMinutes                 Int      @map("duration_minutes")
  status                          AppointmentStatus @default(draft)
  cancellationReason              String?  @map("cancellation_reason")
  noShowReason                    String?  @map("no_show_reason")
  rescheduleCount                 Int      @default(0) @map("reschedule_count")
  previousAppointmentId           String?  @map("previous_appointment_id") @db.Uuid
  serviceAddressLine1Enc          Bytes?   @map("service_address_line1_enc")
  serviceAddressLine2Enc          Bytes?   @map("service_address_line2_enc")
  serviceAddressCity              String?  @map("service_address_city")
  serviceAddressState             String?  @map("service_address_state")
  serviceAddressZip               String?  @map("service_address_zip")
  serviceAddressLat               Float?   @map("service_address_lat")
  serviceAddressLng               Float?   @map("service_address_lng")
  serviceAddressPlaceId           String?  @map("service_address_place_id")
  customerInstructions            String?  @map("customer_instructions")
  internalNotes                   String?  @map("internal_notes")
  subtotalCents                   Int      @default(0) @map("subtotal_cents")
  discountTotalCents              Int      @default(0) @map("discount_total_cents")
  taxCents                        Int      @default(0) @map("tax_cents")
  totalCents                      Int      @default(0) @map("total_cents")
  depositPolicyTypeSnapshot       DepositPolicyType @map("deposit_policy_type_snapshot")
  depositPolicyValueSnapshot      Int      @map("deposit_policy_value_snapshot")
  depositAmountCents              Int      @default(0) @map("deposit_amount_cents")
  depositPaidCents                Int      @default(0) @map("deposit_paid_cents")
  depositPaidAt                   DateTime? @map("deposit_paid_at") @db.Timestamptz
  depositStripePaymentIntentId    String?  @unique @map("deposit_stripe_payment_intent_id")
  depositStatus                   DepositStatus @default(pending) @map("deposit_status")
  depositMethod                   PaymentMethod? @map("deposit_method")
  balanceDueCents                 Int      @default(0) @map("balance_due_cents")
  balanceStatus                   BalanceStatus @default(unpaid) @map("balance_status")
  balanceMethod                   PaymentMethod? @map("balance_method")
  balancePaidAt                   DateTime? @map("balance_paid_at") @db.Timestamptz
  evidencePhotoCount              Int      @default(0) @map("evidence_photo_count")
  loyaltyRedemptionId             String?  @map("loyalty_redemption_id") @db.Uuid
  confirmedAt                     DateTime? @map("confirmed_at") @db.Timestamptz
  onTheWayAt                      DateTime? @map("on_the_way_at") @db.Timestamptz
  arrivedAt                       DateTime? @map("arrived_at") @db.Timestamptz
  startedAt                       DateTime? @map("started_at") @db.Timestamptz
  completedAt                     DateTime? @map("completed_at") @db.Timestamptz
  cancelledAt                     DateTime? @map("cancelled_at") @db.Timestamptz
  noShowAt                        DateTime? @map("no_show_at") @db.Timestamptz
  idempotencyKey                  String?  @unique @map("idempotency_key")
  manageTokenHash                 String?  @map("manage_token_hash")
  source                          String   @default("web")
  createdAt                       DateTime @default(now()) @map("created_at") @db.Timestamptz
  createdByUserId                 String?  @map("created_by_user_id") @db.Uuid
  updatedAt                       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer      Customer @relation(fields: [customerId], references: [id])
  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id])
  zone          Zone     @relation(fields: [zoneId], references: [id])
  resource      Resource @relation(fields: [resourceId], references: [id])
  previous      Appointment? @relation("rescheduleChain", fields: [previousAppointmentId], references: [id])
  rescheduledTo Appointment[] @relation("rescheduleChain")
  createdByUser AppUser? @relation("createdByUser", fields: [createdByUserId], references: [id])

  items            AppointmentItem[]
  statusHistory    AppointmentStatusHistory[]
  appliedDiscounts AppliedDiscount[]
  payments         Payment[]
  evidencePhotos   EvidencePhoto[]
  evidenceConsent  EvidenceConsent?
  receipt          Receipt?
  notifications    Notification[]
  redemptions      LoyaltyRedemption[] @relation("redemptionAppointment")
  loyaltyProgressAsLast LoyaltyProgress[] @relation("lpLastAppt")

  @@index([businessId, startsAt], map: "idx_appointment_business_date")
  @@index([businessId, status, startsAt], map: "idx_appointment_status")
  @@index([businessId, customerId, startsAt(sort: Desc)], map: "idx_appointment_customer")
  @@index([businessId, vehicleId, startsAt(sort: Desc)], map: "idx_appointment_vehicle")
  @@index([businessId, resourceId, startsAt], map: "idx_appointment_resource_day")
  @@map("appointment")
}

model AppointmentItem {
