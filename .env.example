# Splash SaaS — Environment
# Copy to .env.local and fill in values. Never commit .env.local.

# ============ DATABASE ============
# Neon / Postgres connection string
DATABASE_URL="postgresql://splash_app:password@localhost:5432/splash?schema=public"
# Rol con permisos de migración (CREATE/DROP). Usar solo para prisma migrate.
DATABASE_URL_MIGRATIONS="postgresql://splash_migrator:password@localhost:5432/splash?schema=public"

# ============ APP ============
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_BOOKING_HOST_SUFFIX=".splash.app"   # para resolver subdominios
SESSION_SECRET="change-me-32-byte-hex"           # openssl rand -hex 32
MANAGE_TOKEN_SECRET="change-me-32-byte-hex"

# ============ STRIPE ============
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Opcional: usar un secret distinto si creas un endpoint Connect aparte.
# Si no, deja vacío y el mismo STRIPE_WEBHOOK_SECRET aplica a todo.
STRIPE_CONNECT_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Solo para pruebas locales: cuenta Connect de sandbox pre-creada (no usada por el código).
TEST_STRIPE_CONNECTED_ACCOUNT_ID=""

# ============ CLOUDFLARE R2 ============
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_EVIDENCE="splash-evidence"
R2_BUCKET_RECEIPTS="splash-receipts"
R2_PUBLIC_URL_BASE=""   # optional custom domain in front of R2

# ============ EMAIL (Resend) ============
RESEND_API_KEY="re_..."
EMAIL_FROM="Splash <bookings@splash.app>"

# ============ UPSTASH ============
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
UPSTASH_QSTASH_URL="https://qstash.upstash.io"
UPSTASH_QSTASH_TOKEN=""
UPSTASH_QSTASH_CURRENT_SIGNING_KEY=""
UPSTASH_QSTASH_NEXT_SIGNING_KEY=""

# ============ GOOGLE CALENDAR (opcional) ============
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI=""

# ============ SENTRY (opcional) ============
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ============ MAPBOX ============
NEXT_PUBLIC_MAPBOX_TOKEN=""
